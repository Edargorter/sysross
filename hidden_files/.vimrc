syntax on
set title
set number
set backspace=indent,eol,start

" filetype plugin indent on
set directory=/tmp//
set backupdir=/tmp//
set undodir=/tmp//

set tabstop=4
set softtabstop=4
set shiftwidth=4
set noexpandtab
set autoindent
set linebreak

nnoremap j gj
nnoremap k gk
vnoremap j gj
vnoremap k gk

set hlsearch
set ruler
set t_Co=256
highlight Comment ctermfg=green

set nopaste

set noswapfile
set noundofile
set nobackup

set nofsync
